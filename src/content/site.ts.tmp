/* ---- PORTFOLIO ----
   Each project shows in the gallery. `image` is the cover.
   Add as many as you like. */
export type Project = {
  slug: string;
  title: string;
  category: string; // e.g. "Living Space", "Bedroom", "Bathroom"
  year: string;
  image: string; // cover photo
  description: string;
  ready?: boolean; // true once a real photo is in place (else shows a placeholder)
  gallery?: string[]; // detail / close-up shots shown under the cover
};

