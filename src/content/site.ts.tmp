/* ---- LOCAL SEO / AEO ----
   Denise is a Service-Area Business based in Dade City, FL, serving clients
   in person within ~40 miles. These values power the LocalBusiness schema,
   the service-area copy, and the city pages. Update the town list and rates
   here and they propagate everywhere. */
export type Area = {
  slug: string;
  name: string; // city name only
  county: string;
  // Short one-liner for the index cards.
  blurb: string;
  // Answer-first lead paragraph (~45–55 words), written so AI answer engines
  // and Google can lift it cleanly. Unique to each area.
  intro: string;
  // Two short, locally specific paragraphs (unique per area, no duplicate copy).
  body: [string, string];
};

