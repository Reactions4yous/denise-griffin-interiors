# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and never committed.

# --- Contact form email (Resend) ---
# Get a free API key at https://resend.com  ->  API Keys
RESEND_API_KEY=

# Where contact-form submissions are emailed TO (Denise's inbox)
CONTACT_TO_EMAIL=

# The verified "from" address Resend sends as (e.g. hello@denisestyling.com)
CONTACT_FROM_EMAIL=

# --- Booking ---
# Denise's Calendly scheduling link (e.g. https://calendly.com/denise/consultation)
NEXT_PUBLIC_CALENDLY_URL=

# --- Site ---
# Full production URL once the domain is live (used for SEO/sitemap)
NEXT_PUBLIC_SITE_URL=https://www.denisestyling.com
